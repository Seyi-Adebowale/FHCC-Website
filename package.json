{
  "name": "fhcc-website",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "start": "npm-run-all --parallel tailwind:watch react:start",
    "build": "npm run tailwind:build && react-scripts build",
    "react:start": "react-scripts start",
    "tailwind:watch": "npx @tailwindcss/cli -i ./src/index.css -o ./src/tailwind.css --watch",
    "tailwind:build": "npx @tailwindcss/cli -i ./src/index.css -o ./src/tailwind.css --minify",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "framer-motion": "^12.12.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "react-scripts": "5.0.1",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.8",
    "@tailwindcss/cli": "^4.1.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
